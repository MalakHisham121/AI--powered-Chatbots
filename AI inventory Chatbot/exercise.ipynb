    "from Langraph import Graph\n",
    "\n",
    "def addOpeState(a , b):\n",
    "    return a + b\n",
    "\n",
    "def timOpeState(a , b):\n",
    "    return a * b\n",
    "\n",
    "\n",
    "\n",
    "graph = Graph()\n",
    "graph.addNode(\"A\" , 1)\n",
    "graph.addNode(\"B\" , 2)\n",
    "graph.addNode(\"C\" , 3)\n",
    "\n",
    "graph.invoke(\"A\" , \"B\" , addOpeState)"
